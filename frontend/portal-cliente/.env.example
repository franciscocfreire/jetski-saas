# Portal do Cliente — variáveis de ambiente (copie para .env.local em dev)

# Keycloak (client público jetski-customer-portal, PKCE — mesmo realm do backoffice)
KEYCLOAK_CLIENT_ID=jetski-customer-portal
KEYCLOAK_ISSUER=http://localhost:8080/realms/jetski-saas

# NextAuth
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=troque-este-valor-em-producao
AUTH_TRUST_HOST=true

# Backend
NEXT_PUBLIC_API_URL=http://localhost:8090/api
