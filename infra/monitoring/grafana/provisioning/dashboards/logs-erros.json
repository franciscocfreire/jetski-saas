    {
      "id": 3,
      "type": "bargauge",
      "title": "Top exceções (janela atual)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "description": "Classes *Exception/*Error mais frequentes nos logs do backend no intervalo de tempo selecionado",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#e66767"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#e66767",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "minVizHeight": 16,
        "minVizWidth": 8,
        "maxVizHeight": 300,
        "namePlacement": "top",
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "topk(10, sum by (exception) (count_over_time({service=\"backend\"} |~ `(Exception|Error)` | regexp `(?P<exception>[A-Za-z0-9$.]+(Exception|Error))` | exception!=\"\" [$__range])))",
          "legendFormat": "{{exception}}",
          "queryType": "instant",
          "refId": "A"
        }
      ]
    },
