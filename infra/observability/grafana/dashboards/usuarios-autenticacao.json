{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["jetski", "prod", "auth"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Jetski — Usuários & Autenticação",
  "uid": "jetski-usuarios-auth",
  "version": 1,
  "weekStart": "",
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "janela",
        "label": "Janela (logins recentes)",
        "type": "interval",
        "query": "5m,15m,30m,1h,3h",
        "current": { "selected": true, "text": "15m", "value": "15m" },
        "options": [
          { "selected": false, "text": "5m", "value": "5m" },
          { "selected": true, "text": "15m", "value": "15m" },
          { "selected": false, "text": "30m", "value": "30m" },
          { "selected": false, "text": "1h", "value": "1h" },
          { "selected": false, "text": "3h", "value": "3h" }
        ],
        "hide": 0,
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sessões ativas (total)",
      "description": "Sessões abertas no Keycloak agora (Admin API client-session-stats, poller do backend)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto",
        "textMode": "auto", "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(jetski_keycloak_sessoes_ativas)",
          "refId": "A", "instant": true, "range": false
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sessões por client",
      "description": "Backoffice × portal do cliente",
      "gridPos": { "h": 4, "w": 6, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "textMode": "value_and_name", "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "jetski_keycloak_sessoes_ativas",
          "legendFormat": "{{client_id}}",
          "refId": "A", "instant": true, "range": false
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Logins (últimos $janela)",
      "description": "Logins com sucesso no realm jetski-saas (métrica nativa do Keycloak 26.4)",
      "gridPos": { "h": 4, "w": 4, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto",
        "textMode": "auto", "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"login\", error=\"\"}[$janela]))",
          "refId": "A", "instant": true, "range": false
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Falhas de login (últimos $janela)",
      "description": "Tentativas de login com erro (credencial inválida, conta bloqueada etc.)",
      "gridPos": { "h": 4, "w": 4, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto",
        "textMode": "auto", "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"login\", error!=\"\"}[$janela]))",
          "refId": "A", "instant": true, "range": false
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Staff cadastrado",
      "description": "Usuários ativos do backoffice (tabela usuario)",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "decimals": 0,
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "textMode": "auto", "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "jetski_usuarios_cadastrados",
          "refId": "A", "instant": true, "range": false
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Clientes cadastrados",
      "description": "Clientes de todas as empresas (portal + balcão)",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "decimals": 0,
          "noValue": "—"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto",
        "textMode": "auto", "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "jetski_clientes_cadastrados",
          "refId": "A", "instant": true, "range": false
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Logins por client",
      "description": "Logins com sucesso ao longo do tempo, separados por aplicação",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "barAlignment": 0,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never", "spanNulls": false,
            "axisLabel": "", "axisPlacement": "auto", "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (client_id) (increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"login\", error=\"\"}[$__interval]))",
          "legendFormat": "{{client_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Falhas de login por motivo",
      "description": "Erros de autenticação — pico sustentado pode indicar ataque de força bruta",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "barAlignment": 0,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never", "spanNulls": false,
            "axisLabel": "", "axisPlacement": "auto", "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (error) (increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"login\", error!=\"\"}[$__interval]))",
          "legendFormat": "{{error}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Sessões ativas ao longo do tempo",
      "description": "Evolução das sessões abertas por client",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "barAlignment": 0,
            "stacking": { "mode": "none", "group": "A" },
            "showPoints": "never", "spanNulls": true,
            "axisLabel": "", "axisPlacement": "auto", "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "jetski_keycloak_sessoes_ativas",
          "legendFormat": "{{client_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Novos cadastros e logouts",
      "description": "Eventos register/logout do realm (métrica nativa do Keycloak)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "barAlignment": 0,
            "stacking": { "mode": "none", "group": "A" },
            "showPoints": "never", "spanNulls": false,
            "axisLabel": "", "axisPlacement": "auto", "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"register\", error=\"\"}[$__interval]))",
          "legendFormat": "cadastros",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"logout\", error=\"\"}[$__interval]))",
          "legendFormat": "logouts",
          "refId": "B"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Renovações de token: sucesso × falha",
      "description": "Refreshes server-side do NextAuth (backoffice e portal). Falha aqui é sinal real: revogação server-side, logout em outro dispositivo ou replay — o front não tenta renovar token já vencido desde jul/2026.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "barAlignment": 0,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never", "spanNulls": false,
            "axisLabel": "", "axisPlacement": "auto", "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "decimals": 0,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (client_id) (increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"refresh_token\", error=\"\"}[$__interval]))",
          "legendFormat": "ok — {{client_id}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum by (client_id, error) (increase(keycloak_user_events_total{realm=\"jetski-saas\", event=\"refresh_token\", error!=\"\"}[$__interval]))",
          "legendFormat": "FALHA {{error}} — {{client_id}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Taxa de falha de renovação (%)",
      "description": "REFRESH_TOKEN_ERROR / total de refreshes. Ruído normal ≈ 0-2%; salto sustentado = regressão no client (sessão zumbi) ou tentativa de replay. Alerta dispara por volume absoluto sustentado (ver regra \"Falhas de renovação de token\").",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "barAlignment": 0,
            "stacking": { "mode": "none", "group": "A" },
            "showPoints": "never", "spanNulls": false,
            "axisLabel": "", "axisPlacement": "auto", "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "100 * sum(rate(keycloak_user_events_total{realm=\"jetski-saas\", event=\"refresh_token\", error!=\"\"}[15m])) / sum(rate(keycloak_user_events_total{realm=\"jetski-saas\", event=\"refresh_token\"}[15m]))",
          "legendFormat": "taxa de falha (janela 15m)",
          "refId": "A"
        }
      ]
    }
  ]
}
