# =============================================================================
# Variáveis de PRODUÇÃO — copie para `.env` no servidor e preencha os segredos.
#   cp .env.prod.example .env && nano .env
# O arquivo `.env` é lido automaticamente pelo docker compose. NUNCA commitar `.env`.
# =============================================================================

# URL pública (Cloudflare Tunnel) — sem barra no final
PUBLIC_URL=https://pegaojet.com.br

# --- PostgreSQL ---
# Senha do superuser `jetski` (dono do banco; usado pelo Flyway e Keycloak)
POSTGRES_PASSWORD=troque-esta-senha-forte
# Senha do role de aplicação `jetski_app` (NOSUPERUSER NOBYPASSRLS — RLS ativo)
JETSKI_APP_DB_PASSWORD=troque-esta-senha-app

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=troque-admin-keycloak
# Secret do client confidencial do backoffice (deve casar com o realm)
KEYCLOAK_BACKOFFICE_SECRET=backoffice-secret

# --- NextAuth (backoffice) ---
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-openssl-rand-base64-32

# --- MinIO (storage de documentos/fotos) ---
MINIO_ROOT_USER=jetski-minio
MINIO_ROOT_PASSWORD=troque-minio-senha-forte
MINIO_BUCKET=jetski-docs

# --- Cloudflare Tunnel ---
# Token do tunnel nomeado (painel Zero Trust → Tunnels → seu tunnel → Install)
CLOUDFLARE_TUNNEL_TOKEN=cole-o-token-do-tunnel-aqui

# --- E-mail (opcional; ativação de cliente, convites) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
