# =============================================================================
# Variáveis de PRODUÇÃO — copie para `.env` no servidor e preencha os segredos.
#   cp .env.prod.example .env && nano .env
# O arquivo `.env` é lido automaticamente pelo docker compose. NUNCA commitar `.env`.
# =============================================================================

# URL pública (Cloudflare Tunnel) — sem barra no final
PUBLIC_URL=https://jetsave.com.br

# --- PostgreSQL ---
# Senha do superuser `jetski` (dono do banco; usado pelo Flyway e Keycloak)
POSTGRES_PASSWORD=troque-esta-senha-forte
# Senha do role de aplicação `jetski_app` (NOSUPERUSER NOBYPASSRLS — RLS ativo)
JETSKI_APP_DB_PASSWORD=troque-esta-senha-app

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=troque-admin-keycloak
# (Obsoleto) client backoffice agora é público + PKCE — sem secret. Mantido só p/ compat.
KEYCLOAK_BACKOFFICE_SECRET=backoffice-secret

# --- Super admin de plataforma ---
# Emails (separados por vírgula) promovidos no boot a unrestricted_access=true.
# O usuário precisa já existir (cadastrado); aplica-se no boot seguinte caso contrário.
PLATFORM_ADMIN_EMAILS=

# --- NextAuth (backoffice) ---
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-openssl-rand-base64-32

# --- MinIO (storage de documentos/fotos) ---
MINIO_ROOT_USER=jetski-minio
MINIO_ROOT_PASSWORD=troque-minio-senha-forte
MINIO_BUCKET=jetski-docs

# --- Cloudflare Tunnel ---
# Token do tunnel nomeado (painel Zero Trust → Tunnels → seu tunnel → Install)
CLOUDFLARE_TUNNEL_TOKEN=cole-o-token-do-tunnel-aqui

# --- E-mail (opcional; ativação de cliente, convites) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Criptografia de segredos em repouso (senha SMTP por tenant) ---
# Chave-mestra (fora do banco). Gere com: openssl rand -base64 32
# (o deploy.sh gera automaticamente se estiver vazia). Faça BACKUP dela.
JETSKI_SECRET_KEY=
# Rotação de chave: ao trocar a SECRET_KEY, ponha a chave ANTIGA aqui (decifra os
# segredos ainda não re-cifrados). Remova depois que tudo for re-salvo/migrado.
JETSKI_SECRET_KEY_PREVIOUS=

# --- Observabilidade (infra/observability) ---
# Senha do admin do Grafana (https://SEU_HOST/grafana). Obrigatória p/ subir o stack.
GRAFANA_ADMIN_PASSWORD=troque-esta-senha
# Alertas do Grafana por e-mail (SMTP reaproveita GMAIL_USER/GMAIL_APP_PASSWORD).
# Sem valor, os alertas vão para o próprio GMAIL_USER.
GRAFANA_ALERT_EMAIL=
# Login no Grafana via Keycloak: secret é gerado pelo deploy na 1ª execução;
# GRAFANA_ADMIN_EMAILS (vírgula) recebe a role grafana_admin no realm.
GRAFANA_OIDC_CLIENT_SECRET=
GRAFANA_ADMIN_EMAILS=
# Nome da rede do app (só mude se o diretório do projeto não for "jetski")
#JETSKI_APP_NETWORK=jetski_jetski-network
